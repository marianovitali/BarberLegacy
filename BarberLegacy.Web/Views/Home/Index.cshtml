@{
    ViewData["Title"] = "Home Page";
}


<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Barber Legacy</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary-blue: #1173d4;
            --bg-dark: #101922;
            --bg-card: #192633;
            --bg-nav: #111a22;
            --accent-gold: #D4AF37;
            --text-muted: #92adc9;
            --border-color: #233648;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: #ffffff;
            overflow-x: hidden;
        }

        /* Navbar Customization */
        .navbar {
            background-color: var(--bg-nav);
            border-bottom: 1px solid var(--border-color);
            padding: 0.75rem 0;
        }
        .navbar-brand {
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .nav-link {
            color: var(--text-muted) !important;
            font-weight: 600;
            font-size: 0.9rem;
            margin: 0 1rem;
            transition: color 0.3s;
        }
        .nav-link:hover {
            color: var(--primary-blue) !important;
        }

        /* Hero Section */
        .hero-section {
            position: relative;
            min-height: 600px;
            display: flex;
            align-items: center;
            background: linear-gradient(rgba(16, 25, 34, 0.75), rgba(16, 25, 34, 0.95)),
                        url("https://lh3.googleusercontent.com/aida-public/AB6AXuADnUa6wfz1mpFYpNpinQF9VEDiM807zxuYvOUuj8CzR-3ocmWPn_XkwXGWBxBRM-d5hk-PFqBMBWNx3CqW9vQnsOdYjn11ojtfw-n9lKr609NGAPNu8ZwtrxPA1P0JvP1xtRQB094jEhPzGPTCq0UcQWQqJU-zgg6z7ohadmEfvxUPn-RXWm34za0AX_WEW2nM9pOjduyleufTNYK4NuiCjXgFJNU76hqIwsW_nvlQvTsDf93YsIA7ihY70pJWPhUs_PAvn38wY7O9");
            background-size: cover;
            background-position: center;
            text-align: center;
        }
        .hero-title {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 900;
            letter-spacing: -1px;
            text-transform: uppercase;
        }
        .hero-subtitle {
            color: var(--text-muted);
            max-width: 700px;
            margin: 1.5rem auto;
            font-size: 1.1rem;
        }

        /* Section Styling */
        section {
            padding: 80px 0;
        }
        .section-title {
            text-transform: uppercase;
            font-weight: 800;
            margin-bottom: 3rem;
            position: relative;
            padding-left: 1rem;
            border-left: 4px solid var(--accent-gold);
        }
        .section-title-centered {
            text-align: center;
            border-left: none;
            padding-left: 0;
        }
        .section-title-centered::after {
            content: '';
            display: block;
            width: 60px;
            height: 4px;
            background: var(--accent-gold);
            margin: 10px auto;
            border-radius: 2px;
        }

        /* Service Cards */
        .service-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
            transition: transform 0.3s, box-shadow 0.3s;
            height: 100%;
        }
        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .service-img {
            height: 200px;
            background-size: cover;
            background-position: center;
        }
        .service-price {
            color: var(--accent-gold);
            font-weight: 700;
            font-size: 1.25rem;
        }
        .service-meta {
            font-size: 0.8rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 5px;
            margin-bottom: 0.5rem;
        }

        /* Barber Cards */
        .barber-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2rem;
            text-align: center;
            transition: transform 0.3s;
        }
        .barber-card:hover {
            transform: translateY(-5px);
        }
        .barber-img {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            margin: 0 auto 1.5rem;
            border: 4px solid var(--border-color);
            background-size: cover;
            background-position: center;
        }

        /* CTA Banner */
        .cta-banner {
            background: linear-gradient(135deg, #101922 0%, #1a2b3c 100%);
            border-radius: 16px;
            padding: 4rem 2rem;
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        /* Map Placeholder */
        .map-box {
            height: 100%;
            min-height: 350px;
            background: url("https://lh3.googleusercontent.com/aida-public/AB6AXuA5Tt95PpZK6dTBBtPNJHEX2wZx_ywTSGFYJYp3pjqFgy-s8iM3vCt3CK3f8_1RRkZ2FZd7u-b2lamUAkreXpG0AHBbDjQHgBswX7lDklzq5Et7BV557JOj537YCl6fQ4v2rRW6QHTnCiLnq8i0ElYZ5j7Uj97CFSraCpe9bNpOJbn-2FaQrLlIhIjaI6SI3d2R1vCJy7cw5SjCOnbpqpbNtbjMB6BgvCv3bNJPGwXdWl_o0UJxqMVV58vLK1a1ybOK8TqxM_Nn_JKg");
            background-size: cover;
            background-position: center;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .map-overlay {
            background: rgba(16, 25, 34, 0.85);
            padding: 1rem 1.5rem;
            border-radius: 8px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* Buttons */
        .btn-primary-urban {
            background-color: var(--primary-blue);
            border-color: var(--primary-blue);
            color: white;
            font-weight: 700;
            padding: 0.6rem 1.5rem;
            border-radius: 8px;
            transition: all 0.3s;
        }
        .btn-primary-urban:hover {
            background-color: #0d61b3;
            border-color: #0d61b3;
            transform: scale(1.02);
            color: white;
        }
        .btn-outline-urban {
            background-color: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            font-weight: 700;
            padding: 0.6rem 1.5rem;
            border-radius: 8px;
            transition: all 0.3s;
        }
        .btn-outline-urban:hover {
            background-color: rgba(255,255,255,0.1);
            border-color: white;
            color: white;
        }

        /* Utils */
        .text-gold { color: var(--accent-gold); }
        .text-slate { color: var(--text-muted); }

        footer {
            border-top: 1px solid var(--border-color);
            padding: 4rem 0 2rem;
        }
    </style>
</head>
